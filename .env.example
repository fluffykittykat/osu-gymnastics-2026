# ────────────────────────────────────────────────────────────────
# CHATBOT AI CONFIGURATION
# ────────────────────────────────────────────────────────────────

# Anthropic API Key for Claude (Required)
# Get this from: https://console.anthropic.com
# 1. Go to https://console.anthropic.com
# 2. Navigate to API Keys
# 3. Create a new API key
# 4. Copy the key (format: sk-ant-xxxxx)
# IMPORTANT: Never commit this to git! .env is in .gitignore
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ────────────────────────────────────────────────────────────────

# Port to run the server on
# Default: 8888
PORT=8888

# Optional: Secret for refresh endpoint (/api/refresh)
# Used to authenticate data refresh requests from external systems
# If not set, /api/refresh endpoint is unprotected (development only)
REFRESH_SECRET=your-secret-key-here

# ────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ────────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your actual API key
# 3. Run: npm start
# 4. Open http://localhost:8888 in your browser
# 5. Click the chatbot bubble (💬) and test
# 
# For more details, see CHATBOT_SETUP.md
